---
import type { SiteLocale } from '../lib/ui';
import { toRelativePath } from '../lib/relative-url';
import { SITE_COPY } from '../lib/ui';
import {
  buildDocsArticleLink,
  buildDocsCategoryLink,
  getSiteData,
  getLocalizedValue,
  getVisibleArticles
} from '../../scripts/site-data.mjs';

interface Props {
  locale: SiteLocale;
}

const { locale } = Astro.props;
const copy = SITE_COPY[locale];
const siteData = getSiteData();
const changelog = siteData.categories.find((category) => category.slug === 'changelog');
const latestArticles = getVisibleArticles(changelog?.articles ?? [], locale).slice(0, 8).map((article) => {
  const translation = article.translations[locale] ?? article.translations.root;
  const targetPathname = buildDocsArticleLink(locale, 'changelog', article.slug);
  return {
    title: translation.title,
    description: translation.description,
    date: article.date,
    href: toRelativePath(Astro.url.pathname, targetPathname)
  };
});
---

<div class="modern-home home-content">
  <!-- Categories Section -->
  <section class="modern-section" aria-labelledby={`home-${locale}-categories`}>
    <div class="section-header">
      <h2 id={`home-${locale}-categories`}>{copy.sections.categories}</h2>
      <div class="header-line"></div>
    </div>
    
    <div class="bento-grid">
      {siteData.categories.map((category) => {
        const visibleArticles = getVisibleArticles(category.articles, locale);
        const targetPathname = buildDocsCategoryLink(locale, category.slug);
        return (
          <a href={toRelativePath(Astro.url.pathname, targetPathname)} class="bento-card">
            <div class="bento-card-bg"></div>
            <div class="bento-card-content">
              <div class="bento-card-header">
                <h3>{getLocalizedValue(category.titles, locale)}</h3>
                <span class="article-badge">{visibleArticles.length} {copy.labels.articleCount}</span>
              </div>
              <p class="bento-description">{getLocalizedValue(category.descriptions, locale) || copy.labels.noDescription}</p>
              <div class="bento-footer">
                <span>{copy.labels.openCategory}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-arrow">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Latest Updates Section -->
  <section class="modern-section" aria-labelledby={`home-${locale}-latest`}>
    <div class="section-header">
      <h2 id={`home-${locale}-latest`}>{copy.sections.latest}</h2>
      <div class="header-line"></div>
    </div>
    
    <div class="updates-list">
      {latestArticles.map((article) => (
        <a href={article.href} class="update-row">
          <div class="update-date">
            <span class="date-text">{article.date}</span>
          </div>
          <div class="update-content">
            <h3 class="update-title">{article.title}</h3>
            <p class="update-desc">{article.description || copy.labels.noDescription}</p>
          </div>
          <div class="update-action">
            <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</div>

<style>
  /* Base Container */
  .modern-home {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 1rem;
    animation: fade-in 0.6s ease-out;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Section Headers */
  .modern-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2vw + 1rem, 1.8rem);
    font-weight: 700;
    color: var(--sl-color-white);
    letter-spacing: -0.02em;
    position: relative;
  }

  .header-line {
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--site-line) 0%, transparent 100%);
    opacity: 0.6;
  }

  /* Bento Grid for Categories */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .bento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    padding: 1px; /* for gradient border effect */
    background: var(--site-line);
    text-decoration: none !important;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.3s ease;
  }

  .bento-card-bg {
    position: absolute;
    inset: 1px;
    background: var(--site-bg-panel);
    border-radius: calc(1rem - 1px);
    z-index: 0;
    transition: background 0.3s ease;
  }

  .bento-card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
  }

  .bento-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: var(--site-shadow-strong);
    background: linear-gradient(135deg, var(--sl-color-accent), var(--site-line));
  }

  .bento-card:hover .bento-card-bg {
    background: var(--site-bg-panel-strong);
  }

  .bento-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }

  .bento-card-header h3 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .bento-card:hover .bento-card-header h3 {
    color: var(--site-link-hover);
  }

  .article-badge {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    background: color-mix(in srgb, var(--sl-color-accent-low) 50%, transparent);
    color: var(--sl-color-accent-high);
    border-radius: 2rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
  }

  .bento-description {
    margin: 0 0 1.5rem 0;
    font-size: 0.95rem;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
    flex-grow: 1;
  }

  .bento-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--site-link);
    margin-top: auto;
  }

  .icon-arrow {
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .bento-card:hover .icon-arrow {
    transform: translateX(4px);
  }

  /* Latest Updates List */
  .updates-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .update-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--site-bg-panel);
    border: 1px solid var(--site-line);
    border-radius: 0.75rem;
    text-decoration: none !important;
    transition: all 0.2s ease;
  }

  .update-row:hover {
    background: var(--site-bg-panel-strong);
    border-color: color-mix(in srgb, var(--sl-color-accent) 40%, var(--site-line));
    transform: translateX(4px);
    box-shadow: var(--site-shadow);
  }

  .update-date {
    flex-shrink: 0;
    width: 100px;
  }

  .date-text {
    font-family: var(--sl-font-mono), monospace;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
  }

  .update-row:hover .date-text {
    color: var(--sl-color-accent);
  }

  .update-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0; /* allows text truncation */
  }

  .update-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .update-row:hover .update-title {
    color: var(--site-link-hover);
  }

  .update-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .update-action {
    flex-shrink: 0;
    color: var(--sl-color-gray-4);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .update-row:hover .update-action {
    opacity: 1;
    transform: translateX(0);
    color: var(--sl-color-accent);
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .update-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1rem 1.25rem;
    }
    
    .update-date {
      width: auto;
    }
    
    .update-content {
      width: 100%;
    }
    
    .update-title, .update-desc {
      white-space: normal;
    }
    
    .update-action {
      display: none;
    }
    
    .bento-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
